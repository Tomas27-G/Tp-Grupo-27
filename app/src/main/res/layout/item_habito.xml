<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical">

    <CheckBox
        android:id="@+id/checkRealizado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:buttonTint="@color/verde_android"
        android:text="" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_weight="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/tvNombreHabito"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre hábito"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvFechaInicioHabito"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Inicio: 01/01/2026"
            android:textSize="14sp"
            android:textColor="#666"/>

    </LinearLayout>

    <ImageButton
        android:id="@+id/btnModificar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Modificar hábito"
        android:src="@android:drawable/ic_menu_edit"/>

    <ImageButton
        android:id="@+id/btnEliminar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Eliminar hábito"
        android:src="@android:drawable/ic_menu_delete" />

</LinearLayout>